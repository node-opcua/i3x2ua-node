# ── OPC UA Connection ──
I3X_OPCUA_ENDPOINT=opc.tcp://localhost:4840
I3X_OPCUA_SECURITY_MODE=None
I3X_OPCUA_BROWSE_CONCURRENCY=16
I3X_OPCUA_METADATA_CACHE_TTL_SECONDS=300

# ── Model ──
I3X_MODEL_REFRESH_INTERVAL_SECONDS=60
I3X_MODEL_PRELOAD_ON_STARTUP=true
I3X_FAIL_STARTUP_ON_MODEL_PRELOAD_ERROR=false

# ── Subscriptions ──
I3X_SUBSCRIPTION_INTERVAL_SECONDS=5

# ── Server ──
I3X_PORT=8000
I3X_HOST=127.0.0.1
I3X_LOG_LEVEL=info

# ── Development ──
I3X_SKIP_OPCUA_CONNECT=0

# ── Optimized Client ──
# auto = detect and use if installed, disabled = skip
I3X_OPCUA_OPTIMIZED_CLIENT=auto
